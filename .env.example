## Example environment variables for RH Flow backend
# Required

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=mydb

# Primary database URL (SQLAlchemy format)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mydb

# Application secret used to sign JWTs — keep this secret in production
SECRET_KEY=replace_with_a_random_secret_key

# Optional (defaults shown in code)

# Environment (development, staging, production)
ENVIRONMENT=development

# App settings
APP_NAME=RH Flow

# JWT settings
ALGORITHM=HS256
# Access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Misc
DEBUG=False

# Notes:
# - Copy this file to `.env` and fill in real secrets before running the app.
# - Use a securely generated `SECRET_KEY` in production.
# - For Docker Compose: ensure PostgreSQL credentials match POSTGRES_* variables.
# - For Docker Compose: ensure MinIO credentials match MINIO_* variables.