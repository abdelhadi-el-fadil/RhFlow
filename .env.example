# Example environment variables for RH Flow.
# Copy this file to `.env` (repo root, next to docker-compose.yml) and fill in real values.
# Read by: backend Settings (app/config.py) AND docker-compose variable substitution.

# --- Required (no defaults — app fails fast if missing) ---

# Primary database URL (SQLAlchemy format) — user/password/db MUST match POSTGRES_* below
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rhflow

# Application secret used to sign JWTs — use a securely generated value in production
SECRET_KEY=replace_with_a_random_secret_key_at_least_32_chars

# --- Optional (defaults shown in app/config.py) ---

APP_NAME=RH Flow v2
DEBUG=False
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
MINIO_ENDPOINT=localhost:9000

# --- Docker Compose only (not read by the backend) ---

# PostgreSQL container init — keep in sync with DATABASE_URL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=rhflow

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# pgAdmin (http://localhost:5050)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
