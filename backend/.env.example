## Example environment variables for RH Flow backend
# Required
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mydb
SECRET_KEY=replace_with_a_random_secret_key

# Optional (defaults shown in code)
# ALGORITHM used for JWT encoding
ALGORITHM=HS256
# Access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App settings
APP_NAME=RH Flow v2
# Set to true for verbose logging and debug mode
DEBUG=False

# Notes:
# - Copy this file to `.env` and fill in real secrets before running the app.
# - Use a securely generated `SECRET_KEY` in production.